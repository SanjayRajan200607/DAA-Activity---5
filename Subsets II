class Solution(object):
    def subsets(self, nums):
        """
        :type nums: List[int]
        :rtype: List[List[int]]
        """
        result = [[]]
        
        for num in nums:
            # For every existing subset, create a new one with the current 'num' appended
            result += [curr + [num] for curr in result]
            
        return result
